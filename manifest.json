{
  "manifest_version": 3,
  "name": "Custom 7TV Emote Menu by Int32",
  "version": "1.2",
  "permissions": [], 
  "host_permissions": [
    "https://www.twitch.tv/*",
    "https://decapi.me/*",
    "https://7tv.io/*"
  ],
  "content_scripts": [
    {
      "matches": ["https://www.twitch.tv/*"],
      "js": ["content.js"],
      "css": ["inject.css"]
    }
  ],
  "web_accessible_resources": [
    {
      "resources": ["icons/*.png","popup.html", "popup.js"],
      "matches": ["https://www.twitch.tv/*"]
    }
  ]
}